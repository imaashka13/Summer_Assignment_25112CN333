import java.util.*;
public class p4
{
    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter a number:");
        int n=sc.nextInt();
        int a=n;
        int count=0;
        while(n>0)
        {
            n=n/10;
            count++;
        }
        System.out.println("The digits of "+a+"="+count);
    }
}
