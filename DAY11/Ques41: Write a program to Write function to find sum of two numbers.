import java.util.*;
public class p41
{
    public static int Sum(int a, int b) 
    {
        return (a+b);
    }
    public static void main(String[] args) 
    {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter first number: ");
        int n1=sc.nextInt();
        System.out.print("Enter second number: ");
        int n2=sc.nextInt();
        int sum=Sum(n1,n2);
        System.out.println("Sum = "+sum);
    }
}
