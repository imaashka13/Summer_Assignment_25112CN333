import java.util.*;
public class p2
{
    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter a number to reverse:");
        int n=sc.nextInt();
        int rev=0; int r, a;
        a=n;
        while(n>0)
        {
            r=n%10;
            rev=rev*10 + r;
            n=n/10;
            
        }
        System.out.println("The reverse of "+a+": "+rev);
    }
}
