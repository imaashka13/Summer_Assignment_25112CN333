import java.util.*;
public class p7
{
    public static void main(String[] args) 
    {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter a number:");
        int n=sc.nextInt();
        int a=n;
        int p=1;
        int r;
        while(n>0)
        {
            r=n%10;
            p=p*r;
            n=n/10;
        }
        System.out.println("The product of digits of "+a+":"+p);

    }
}
