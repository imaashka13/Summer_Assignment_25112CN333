import java.util.*;
public class p14
{
    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter the value of n:");
        int n=sc.nextInt();
        if(n<=0)
            System.out.println("The Fibonacci term is 0");
        else if(n==1)
            System.out.println("The Fibonacci term is 1");
        else
        {
        int a=0;
        int b=1;
        int c=0;
        for(int i=2; i<=n; i++)
        {
            c=a+b;
            a=b;
            b=c;
        }
        System.out.println("Fibonacci series upto "+n+" term is: "+c);
        }
        
    }
}
