import java.util.*;
public class p20
{
    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter a number:");
        int n=sc.nextInt();
        int l=-1;  //flag variable for largest prime factor
        for(int i=1;i<=n;i++)
        {
            if(n%i==0)
            {
                int c=0;   //to find the prime factors of number entered
                for(int j=1; j<=i; j++)
                {
                    if(i%j==0)
                        c++;
                }
                if(c==2)
                    l=i;
            }
        }
        if(l==-1)
            System.out.println("The number "+n+" has no prime factors.");
        else
            System.out.println("The largest prime factor is: "+l);
        
    }
}
